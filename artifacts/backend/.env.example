PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/filmera_mobile
ALLOWED_ORIGINS=*
PASSWORD_RESET_URL=filmera://reset-password
# Use the exact URL shown by Expo when running the project, ending in /--/reset-password.
EXPO_GO_RESET_URL=exp://192.168.1.20:8081/--/reset-password
PUBLIC_BACKEND_URL=https://filmera-mobile.onrender.com
RESEND_API_KEY=re_your_api_key
SMTP_FROM=FILMERA <no-reply@filmera.us>
